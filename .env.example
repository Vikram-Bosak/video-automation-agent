# ─── Google Credentials ───────────────────────────────────────────────────────
# Service Account JSON को base64 में encode करके यहाँ paste करें
# Command: base64 -w 0 service_account.json
GOOGLE_CREDENTIALS=

# ─── Google Sheet ─────────────────────────────────────────────────────────────
# Sheet URL से ID: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
SHEET_ID=
SHEET_NAME='KidoBum_90Day_Prompts.csv'
SHEET_RANGE=A:F

# Column positions (0-indexed: A=0, B=1, C=2...)
COL_TITLE=0
COL_PROMPT1=1
COL_PROMPT2=2
COL_PROMPT3=3
COL_STATUS=4
COL_DRIVE_LINK=5

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Folder URL से ID: https://drive.google.com/drive/folders/[FOLDER_ID]
DRIVE_FOLDER_ID=

# ─── AI Video Website ─────────────────────────────────────────────────────────
WEBSITE_URL=https://klingai.com
WEBSITE_EMAIL=your_email@gmail.com
WEBSITE_PASSWORD=your_password

# ─── Browser Settings ─────────────────────────────────────────────────────────
BROWSER_HEADLESS=false    # Local testing: false | GitHub Actions: true
BROWSER_SLOW_MO=100       # ms delay (human-like)

# ─── Video Generation ─────────────────────────────────────────────────────────
VIDEO_GEN_TIMEOUT_SEC=600  # 10 minutes max wait for video
MAX_VIDEOS_PER_RUN=1
PROMPTS_PER_VIDEO=3

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
